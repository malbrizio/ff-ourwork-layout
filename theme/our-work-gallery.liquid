{%- comment -%}
  ========================================
  Our Work Gallery — Forever Fierce
  NEW layout only: Layout A (desktop) + Layout M (mobile)
  15 design-example heroes from theme assets.
  ========================================
{%- endcomment -%}

{%- comment -%} Fixed 15-shot set: asset | role | caption | alt {%- endcomment -%}
{%- capture hero_map -%}
ff-ow-hero-15.jpg|open_feature|Location identity · St. Louis|Design example: location skyline print in pink and black
ff-ow-hero-10.jpg|open_stack|Minimal left chest|Design example: minimal left-chest print on mineral wash tee
ff-ow-hero-08.jpg|open_stack|Brand mark · back print|Design example: circular brand mark back print on black tee
ff-ow-hero-01.jpg|triptych|Raglan · crest|Design example: crest print on white and black raglan
ff-ow-hero-03.jpg|triptych|Collegiate mark|Design example: collegiate mark on navy tee
ff-ow-hero-11.jpg|triptych|Brush type|Design example: brush type chest print on grey tee
ff-ow-hero-04.jpg|detail|Script wordmark|Design example: script wordmark on heather raglan
ff-ow-hero-05.jpg|detail|Full back print|Design example: full back badge print on white tee
ff-ow-hero-07.jpg|detail|Embroidery · hoodie|Design example: hoodie embroidery close-up
ff-ow-hero-09.jpg|color|Color + circular mark|Design example: circular mark on blue muscle tank
ff-ow-hero-13.jpg|color|Halftone texture|Design example: purple halftone type on lavender tee
ff-ow-hero-06.jpg|bento_feature|Illustrated type · Indiana|Design example: illustrated type print on mineral wash tee
ff-ow-hero-02.jpg|bento_stack|Lift Local series|Design example: Lift Local series chest print
ff-ow-hero-12.jpg|bento_stack|Back print · bubble type|Design example: bubble type back print on black tee
ff-ow-hero-14.jpg|close|Craft close-up · embroidery|Design example: embroidery craft close-up
{%- endcapture -%}
{%- assign hero_lines = hero_map | strip | split: '
' -%}

<section class="ff-ow" data-section-id="{{ section.id }}">

  {%- if section.settings.eyebrow != blank or section.settings.title != blank or section.settings.subheading != blank -%}
  <header class="ff-ow__header">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ff-ow__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h1 class="ff-ow__title">{{ section.settings.title | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ff-ow__sub">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </header>
  {%- endif -%}

  {%- if section.settings.show_stats -%}
  <div class="ff-ow__stats">
    <div class="ff-ow__stat">
      <span class="ff-ow__stat-num">{{ section.settings.stat_1_number | escape }}</span>
      <span class="ff-ow__stat-label">{{ section.settings.stat_1_label | escape }}</span>
    </div>
    <div class="ff-ow__stat">
      <span class="ff-ow__stat-num">{{ section.settings.stat_2_number | escape }}</span>
      <span class="ff-ow__stat-label">{{ section.settings.stat_2_label | escape }}</span>
    </div>
    <div class="ff-ow__stat">
      <span class="ff-ow__stat-num">{{ section.settings.stat_3_number | escape }}</span>
      <span class="ff-ow__stat-label">{{ section.settings.stat_3_label | escape }}</span>
    </div>
    <div class="ff-ow__stat">
      <span class="ff-ow__stat-num">{{ section.settings.stat_4_number | escape }}</span>
      <span class="ff-ow__stat-label">{{ section.settings.stat_4_label | escape }}</span>
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ========== DESKTOP: Layout A ========== {%- endcomment -%}
  <div class="ff-ow__desk">

    <div class="ff-ow__band ff-ow__band--open">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'open_feature' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile ff-ow__tile--feat', sizes: '(max-width: 900px) 100vw, 58vw', loading: 'eager' -%}
        {%- endif -%}
      {%- endfor -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'open_stack' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 100vw, 38vw', loading: 'eager' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow__band ff-ow__band--3 ff-ow__band--portrait">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'triptych' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 50vw, 33vw' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow__band ff-ow__band--3 ff-ow__band--land">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'detail' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 50vw, 33vw' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow__band ff-ow__band--color">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'color' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 100vw, 50vw' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow__band ff-ow__band--bento">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'bento_feature' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile ff-ow__tile--feat', sizes: '(max-width: 900px) 100vw, 55vw' -%}
        {%- endif -%}
      {%- endfor -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'bento_stack' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 100vw, 40vw' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow__band ff-ow__band--close">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'close' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '(max-width: 900px) 100vw, 720px' -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- comment -%} ========== MOBILE: Layout M ========== {%- endcomment -%}
  <div class="ff-ow__mobi">

    <div class="ff-ow-m__hero">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'open_feature' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '100vw', loading: 'eager', show_cap: true -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign inset_done = false -%}
    {%- for line in hero_lines -%}
      {%- assign p = line | strip | split: '|' -%}
      {%- if p[1] == 'open_stack' and inset_done == false -%}
        <div class="ff-ow-m__inset">
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '92vw', show_cap: true -%}
        </div>
        {%- assign inset_done = true -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="ff-ow-m__pair">
      {%- assign pair_count = 0 -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'triptych' and pair_count < 2 -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '48vw', show_cap: true -%}
          {%- assign pair_count = pair_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <p class="ff-ow-m__rail-label">Print detail</p>
    <div class="ff-ow-m__rail" aria-label="Horizontal detail gallery">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'detail' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '78vw', show_cap: true -%}
        {%- endif -%}
      {%- endfor -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'close' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '78vw', show_cap: true -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- assign color_i = 0 -%}
    {%- for line in hero_lines -%}
      {%- assign p = line | strip | split: '|' -%}
      {%- if p[1] == 'color' -%}
        {%- if color_i == 0 -%}
          <div class="ff-ow-m__bleed">
            {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '100vw', show_cap: true -%}
          </div>
        {%- endif -%}
        {%- assign color_i = color_i | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    <div class="ff-ow-m__stack">
      {%- assign color_i = 0 -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'color' -%}
          {%- if color_i > 0 -%}
            {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '100vw', show_cap: true -%}
          {%- endif -%}
          {%- assign color_i = color_i | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'bento_feature' -%}
          <div class="ff-ow-m__inset">
            {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '92vw', show_cap: true -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- assign trip_i = 0 -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'triptych' -%}
          {%- if trip_i >= 2 -%}
            {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '100vw', show_cap: true -%}
          {%- endif -%}
          {%- assign trip_i = trip_i | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign bento_i = 0 -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'bento_stack' -%}
          {%- if bento_i == 0 -%}
            <div class="ff-ow-m__inset">
              {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '92vw', show_cap: true -%}
            </div>
          {%- else -%}
            {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '100vw', show_cap: true -%}
          {%- endif -%}
          {%- assign bento_i = bento_i | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign open_i = 0 -%}
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'open_stack' -%}
          {%- if open_i > 0 -%}
            <div class="ff-ow-m__inset">
              {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '92vw', show_cap: true -%}
            </div>
          {%- endif -%}
          {%- assign open_i = open_i | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="ff-ow-m__close">
      {%- for line in hero_lines -%}
        {%- assign p = line | strip | split: '|' -%}
        {%- if p[1] == 'close' -%}
          {%- render 'our-work-tile-asset', asset: p[0], caption: p[2], alt: p[3], shot_id: p[0], class: 'ff-ow__tile', sizes: '92vw', show_cap: true -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>

  {%- if section.settings.closing_text != blank -%}
    <p class="ff-ow__closing">{{ section.settings.closing_text | escape }}</p>
  {%- endif -%}

  {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
    <div class="ff-ow__foot">
      <a href="{{ section.settings.cta_link }}" class="ff-ow__cta">{{ section.settings.cta_text | escape }}</a>
    </div>
  {%- elsif section.settings.cta_text != blank -%}
    <div class="ff-ow__foot">
      <a href="https://link.webvehicle.com/widget/form/qNgfulV3tUWZ70qJvAN6" class="ff-ow__cta">{{ section.settings.cta_text | escape }}</a>
    </div>
  {%- endif -%}

  <div class="ff-ow-lb" id="ff-ow-lb-{{ section.id }}" role="dialog" aria-modal="true" aria-label="Image viewer" aria-hidden="true">
    <button type="button" class="ff-ow-lb__close" aria-label="Close image viewer">&times;</button>
    <button type="button" class="ff-ow-lb__nav ff-ow-lb__nav--prev" aria-label="Previous image">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
    </button>
    <div class="ff-ow-lb__stage">
      <img class="ff-ow-lb__img" alt="" width="1600" height="1600">
      <div class="ff-ow-lb__meta">
        <p class="ff-ow-lb__caption"></p>
        <p class="ff-ow-lb__counter"></p>
      </div>
    </div>
    <button type="button" class="ff-ow-lb__nav ff-ow-lb__nav--next" aria-label="Next image">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </button>
  </div>

</section>

<style>
  .ff-ow {
    --ff-ow-ink: #0B0B0B;
    --ff-ow-soft: #2a2a2a;
    --ff-ow-muted: #6b6b6b;
    --ff-ow-gap: 10px;
    --ff-ow-r: 4px;
    max-width: 1440px;
    margin: 0 auto;
    padding: 72px 20px 96px;
    font-family: inherit;
    color: var(--ff-ow-ink);
  }
  .ff-ow__header { text-align: center; margin-bottom: 40px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .ff-ow__eyebrow {
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ff-ow-muted); margin: 0 0 14px; font-weight: 600;
  }
  .ff-ow__title {
    font-size: clamp(40px, 7vw, 72px); font-weight: 800; margin: 0 0 18px;
    letter-spacing: -0.03em; line-height: 0.95; text-transform: uppercase; color: var(--ff-ow-ink);
  }
  .ff-ow__sub {
    font-size: 15px; color: var(--ff-ow-soft); max-width: 560px; margin: 0 auto; line-height: 1.65;
  }
  .ff-ow__stats {
    background: var(--ff-ow-ink); border-radius: var(--ff-ow-r); padding: 36px 24px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px;
  }
  .ff-ow__stat { text-align: center; color: #fff; }
  .ff-ow__stat-num { font-size: 28px; font-weight: 700; letter-spacing: -0.02em; display: block; line-height: 1; }
  .ff-ow__stat-label {
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    opacity: 0.65; display: block; margin-top: 10px; font-weight: 500;
  }
  .ff-ow__tile {
    position: relative; display: block; width: 100%; height: 100%;
    background: #111; border-radius: var(--ff-ow-r); overflow: hidden;
    padding: 0; border: 0; cursor: zoom-in; font: inherit; color: inherit;
  }
  .ff-ow__tile img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  button.ff-ow__tile:hover img,
  button.ff-ow__tile:focus-visible img { transform: scale(1.04); }
  button.ff-ow__tile:focus-visible { outline: 2px solid #93D500; outline-offset: 3px; }
  .ff-ow__cap {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 28px 14px 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
    color: #fff; font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; opacity: 0; transform: translateY(6px); transition: 0.3s ease;
    text-align: left;
  }
  button.ff-ow__tile:hover .ff-ow__cap,
  button.ff-ow__tile:focus-visible .ff-ow__cap { opacity: 1; transform: none; }
  .ff-ow__cap--always { opacity: 1; transform: none; }

  .ff-ow__desk { display: block; }
  .ff-ow__mobi { display: none; }
  .ff-ow__band { display: grid; gap: var(--ff-ow-gap); margin-bottom: var(--ff-ow-gap); }
  .ff-ow__band--open {
    grid-template-columns: 1.35fr 0.85fr;
    grid-template-rows: 1fr 1fr;
    min-height: min(72vh, 780px);
  }
  .ff-ow__band--open .ff-ow__tile--feat { grid-row: 1 / -1; }
  .ff-ow__band--3 { grid-template-columns: repeat(3, 1fr); }
  .ff-ow__band--portrait .ff-ow__tile { aspect-ratio: 3 / 4; height: auto; }
  .ff-ow__band--land .ff-ow__tile { aspect-ratio: 5 / 4; height: auto; }
  .ff-ow__band--color {
    grid-template-columns: 1.1fr 0.9fr;
    min-height: min(56vh, 600px);
  }
  .ff-ow__band--bento {
    grid-template-columns: 1.2fr 0.9fr;
    grid-template-rows: 1fr 1fr;
    min-height: min(64vh, 700px);
  }
  .ff-ow__band--bento .ff-ow__tile--feat { grid-row: 1 / -1; }
  .ff-ow__band--close { grid-template-columns: 1fr; }
  .ff-ow__band--close .ff-ow__tile {
    max-width: 920px; margin: 0 auto; aspect-ratio: 5 / 4; height: auto; width: 100%;
  }

  .ff-ow__closing {
    text-align: center; font-size: 15px; color: var(--ff-ow-soft);
    max-width: 520px; margin: 40px auto 24px; line-height: 1.65;
  }
  .ff-ow__foot { text-align: center; }
  .ff-ow__cta {
    display: inline-block; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 16px 28px; background: var(--ff-ow-ink); color: #fff; text-decoration: none;
    font-weight: 700; border-radius: 2px; transition: background 0.2s, color 0.2s;
  }
  .ff-ow__cta:hover, .ff-ow__cta:focus { background: #93D500; color: var(--ff-ow-ink); }

  .ff-ow-lb {
    position: fixed; inset: 0; background: rgba(10,10,10,0.96); z-index: 9999;
    display: none; align-items: center; justify-content: center; padding: 40px 60px;
    opacity: 0; transition: opacity 0.2s ease;
  }
  .ff-ow-lb.is-open { display: flex; opacity: 1; }
  .ff-ow-lb__stage { max-width: 100%; max-height: 100%; display: flex; flex-direction: column; align-items: center; gap: 16px; }
  .ff-ow-lb__img {
    max-width: 100%; max-height: calc(100vh - 160px); width: auto; height: auto;
    object-fit: contain; display: block; border-radius: 4px;
  }
  .ff-ow-lb__meta { text-align: center; color: rgba(255,255,255,0.85); min-height: 20px; }
  .ff-ow-lb__caption { font-size: 14px; margin: 0 0 6px; letter-spacing: 0.02em; }
  .ff-ow-lb__caption:empty { display: none; }
  .ff-ow-lb__counter { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; opacity: 0.5; margin: 0; }
  .ff-ow-lb__close {
    position: absolute; top: 20px; right: 24px; width: 44px; height: 44px; border-radius: 50%;
    background: rgba(255,255,255,0.08); border: 0; color: #fff; font-size: 28px; line-height: 1;
    cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0;
  }
  .ff-ow-lb__close:hover, .ff-ow-lb__close:focus-visible { background: rgba(255,255,255,0.18); outline: none; }
  .ff-ow-lb__nav {
    position: absolute; top: 50%; transform: translateY(-50%); width: 52px; height: 52px;
    border-radius: 50%; background: rgba(255,255,255,0.08); border: 0; color: #fff;
    cursor: pointer; display: flex; align-items: center; justify-content: center; padding: 0;
  }
  .ff-ow-lb__nav:hover, .ff-ow-lb__nav:focus-visible { background: rgba(255,255,255,0.18); outline: none; }
  .ff-ow-lb__nav--prev { left: 24px; }
  .ff-ow-lb__nav--next { right: 24px; }
  body.ff-ow-lb-open { overflow: hidden; }

  @media (max-width: 900px) {
    .ff-ow { padding: 48px 0 64px; }
    .ff-ow__header { padding: 0 20px; margin-bottom: 28px; }
    .ff-ow__title { font-size: clamp(36px, 11vw, 48px); }
    .ff-ow__sub { font-size: 14px; }
    .ff-ow__stats {
      margin: 0 16px 20px; grid-template-columns: repeat(2, 1fr); gap: 20px; padding: 28px 16px;
    }
    .ff-ow__desk { display: none; }
    .ff-ow__mobi { display: block; }

    .ff-ow-m__hero .ff-ow__tile { border-radius: 0; aspect-ratio: 3 / 4; height: auto; }
    .ff-ow-m__inset { padding: 0 18px; margin: 14px 0; }
    .ff-ow-m__inset .ff-ow__tile { border-radius: 6px; aspect-ratio: 4 / 5; height: auto; }
    .ff-ow-m__pair {
      display: grid; grid-template-columns: 1fr 1fr; gap: 6px;
      padding: 0 6px; margin-bottom: 14px;
    }
    .ff-ow-m__pair .ff-ow__tile { aspect-ratio: 3 / 4; height: auto; border-radius: 4px; }
    .ff-ow-m__pair .ff-ow__cap { font-size: 8px; padding: 20px 8px 8px; }
    .ff-ow-m__rail-label {
      font-size: 10px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--ff-ow-muted); padding: 10px 18px 8px; margin: 0;
    }
    .ff-ow-m__rail {
      display: flex; gap: 8px; overflow-x: auto; scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch; padding: 0 18px 16px; margin-bottom: 8px;
      scrollbar-width: none;
    }
    .ff-ow-m__rail::-webkit-scrollbar { height: 0; }
    .ff-ow-m__rail .ff-ow__tile {
      flex: 0 0 78%; aspect-ratio: 5 / 4; height: auto;
      border-radius: 6px; scroll-snap-align: center;
    }
    .ff-ow-m__bleed .ff-ow__tile { border-radius: 0; aspect-ratio: 1 / 1; height: auto; }
    .ff-ow-m__stack .ff-ow__tile { border-radius: 0; aspect-ratio: 4 / 5; height: auto; margin-bottom: 8px; }
    .ff-ow-m__stack .ff-ow-m__inset { margin-bottom: 14px; }
    .ff-ow-m__stack .ff-ow-m__inset .ff-ow__tile { margin-bottom: 0; }
    .ff-ow-m__close { padding: 8px 18px 0; }
    .ff-ow-m__close .ff-ow__tile { border-radius: 6px; aspect-ratio: 5 / 4; height: auto; }

    .ff-ow__mobi .ff-ow__cap { opacity: 1; transform: none; }
    .ff-ow__mobi button.ff-ow__tile:hover img { transform: none; }

    .ff-ow__closing { padding: 0 20px; margin-top: 32px; font-size: 14px; }
    .ff-ow__foot { padding: 0 20px; }
    .ff-ow__cta { width: 100%; max-width: 360px; text-align: center; }
    .ff-ow-lb { padding: 60px 12px 80px; }
    .ff-ow-lb__img { max-height: calc(100vh - 200px); }
    .ff-ow-lb__nav { width: 44px; height: 44px; }
    .ff-ow-lb__nav--prev { left: 8px; }
    .ff-ow-lb__nav--next { right: 8px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ff-ow__tile img, .ff-ow-lb { transition: none; }
    button.ff-ow__tile:hover img { transform: none; }
  }
</style>

<script>
(function() {
  var section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;
  var triggers = section.querySelectorAll('[data-lightbox-trigger]');
  if (!triggers.length) return;
  var lb = section.querySelector('.ff-ow-lb');
  var lbImg = lb.querySelector('.ff-ow-lb__img');
  var lbCaption = lb.querySelector('.ff-ow-lb__caption');
  var lbCounter = lb.querySelector('.ff-ow-lb__counter');
  var btnClose = lb.querySelector('.ff-ow-lb__close');
  var btnPrev = lb.querySelector('.ff-ow-lb__nav--prev');
  var btnNext = lb.querySelector('.ff-ow-lb__nav--next');

  var items = [];
  var indexById = {};
  Array.prototype.forEach.call(triggers, function(t) {
    var id = t.getAttribute('data-shot-id') || t.getAttribute('data-full');
    if (indexById[id] != null) return;
    indexById[id] = items.length;
    items.push({
      id: id,
      full: t.getAttribute('data-full'),
      caption: t.getAttribute('data-caption') || '',
      alt: t.querySelector('img') ? t.querySelector('img').alt : ''
    });
  });

  var currentIndex = 0;
  var lastFocused = null;

  function show(index) {
    currentIndex = (index + items.length) % items.length;
    var item = items[currentIndex];
    lbImg.src = item.full;
    lbImg.alt = item.alt;
    lbCaption.textContent = item.caption;
    lbCounter.textContent = (currentIndex + 1) + ' / ' + items.length;
  }
  function openById(id) {
    var idx = indexById[id];
    if (idx == null) idx = 0;
    lastFocused = document.activeElement;
    show(idx);
    lb.classList.add('is-open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.classList.add('ff-ow-lb-open');
    btnClose.focus();
  }
  function close() {
    lb.classList.remove('is-open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('ff-ow-lb-open');
    lbImg.removeAttribute('src');
    if (lastFocused && lastFocused.focus) lastFocused.focus();
  }

  Array.prototype.forEach.call(triggers, function(t) {
    t.addEventListener('click', function() {
      openById(t.getAttribute('data-shot-id') || t.getAttribute('data-full'));
    });
  });
  btnClose.addEventListener('click', close);
  btnPrev.addEventListener('click', function() { show(currentIndex - 1); });
  btnNext.addEventListener('click', function() { show(currentIndex + 1); });
  lb.addEventListener('click', function(e) { if (e.target === lb) close(); });
  document.addEventListener('keydown', function(e) {
    if (!lb.classList.contains('is-open')) return;
    if (e.key === 'Escape') { e.preventDefault(); close(); }
    else if (e.key === 'ArrowLeft') { e.preventDefault(); show(currentIndex - 1); }
    else if (e.key === 'ArrowRight') { e.preventDefault(); show(currentIndex + 1); }
  });
  var touchStartX = null;
  lb.addEventListener('touchstart', function(e) {
    if (e.touches.length === 1) touchStartX = e.touches[0].clientX;
  }, { passive: true });
  lb.addEventListener('touchend', function(e) {
    if (touchStartX === null) return;
    var dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 50) {
      if (dx > 0) show(currentIndex - 1);
      else show(currentIndex + 1);
    }
    touchStartX = null;
  });
})();
</script>

