{%- comment -%}
  Our Work tile — shared by desk Layout A and mobile Layout M.
  Params: block, class, sizes, loading (optional), show_cap (optional)
{%- endcomment -%}
{%- liquid
  assign img = block.settings.image
  assign alt = block.settings.alt | default: 'Custom gym apparel'
  assign caption = block.settings.caption
  assign shot_id = block.id
  assign load = loading | default: 'lazy'
  assign sizes_attr = sizes | default: '(max-width: 900px) 100vw, 33vw'
  assign tile_class = class | default: 'ff-ow__tile'
-%}
{%- if img != blank -%}
<button
  type="button"
  class="{{ tile_class }}"
  data-lightbox-trigger
  data-shot-id="{{ shot_id }}"
  data-full="{{ img | image_url: width: 2200 }}"
  data-full-srcset="{{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 1600 }} 1600w, {{ img | image_url: width: 2200 }} 2200w"
  data-caption="{{ caption | escape }}"
  aria-label="Expand image: {{ alt | escape }}"
  {{ block.shopify_attributes }}>
  <img
    src="{{ img | image_url: width: 1200 }}"
    srcset="{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 900 }} 900w, {{ img | image_url: width: 1200 }} 1200w, {{ img | image_url: width: 1600 }} 1600w"
    sizes="{{ sizes_attr }}"
    alt="{{ alt | escape }}"
    loading="{{ load }}"
    width="{{ img.width }}"
    height="{{ img.height }}">
  {%- if caption != blank -%}
    <span class="ff-ow__cap{% if show_cap %} ff-ow__cap--always{% endif %}">{{ caption | escape }}</span>
  {%- endif -%}
</button>
{%- endif -%}
